# CoreLink Environment Configuration

# Google OAuth2 Configuration (Optional)
# CoreLink ships with a built-in Client ID - no setup required!
# Only set this if you want to use your own OAuth app
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Microsoft OAuth2 Configuration (Optional)
# CoreLink ships with a built-in Client ID - no setup required!
# Only set this if you want to use your own OAuth app
# MICROSOFT_CLIENT_ID=your-client-id

# Todoist Configuration
# No configuration needed - users connect via personal API token in the UI
# Get token from: https://app.todoist.com/app/settings/integrations/developer

# Server Configuration
PORT=3747
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=./.corelink/corelink.db

# Encryption
ENCRYPTION_KEY_PATH=./.corelink/encryption.key

# CORS
CORS_ORIGIN=http://localhost:5173
